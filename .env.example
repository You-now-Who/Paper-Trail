# Paper Trail — copy to .env and fill in values

# Reddit (create app at https://www.reddit.com/prefs/apps — type "script", read-only)
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=PaperTrail/1.0

# Bluesky (search may require auth; use app password from bsky.app → Settings → App passwords)
BLUESKY_HANDLE=your_handle.bsky.social
BLUESKY_APP_PASSWORD=your_app_password

# OpenAI (for keyword extraction, clustering embeddings, provenance/diff/reply agents)
OPENAI_API_KEY=your_openai_api_key

# Optional: backend host/port (default 127.0.0.1:8000)
# BACKEND_HOST=127.0.0.1
# BACKEND_PORT=8000
